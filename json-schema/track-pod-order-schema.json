    "LoadStatus": {
      "type": "string",
      "description": "Status code: none; loaded; not-loaded;",
      "nullable": true,
      "example": "loaded"
    },
    "LoadDate": {
      "type": "string",
      "description": "Date of Loading",
      "format": "date-time",
      "nullable": true,
      "example": "2019-02-01T15:31:00"
    },
    "LoadSignaturePhotos": {
      "type": "array",
      "items": {
        "type": "string"
      },
