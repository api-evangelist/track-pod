      "nullable": true,
      "xml": {
        "name": "LoadSignaturePhotos",
        "wrapped": true
      }
    },
    "ChangeDate": {
      "type": "string",
      "format": "date-time"
    },
    "RescheduledTimes": {
      "type": "integer",
      "description": "Order rescheduled times",
      "format": "int32",
      "nullable": true,
      "example": 1
    }
  },
  "required": []
}